---
import MarkdownText from "@/components/typography/MarkdownText.astro";
import { useTranslations } from "@/i18n/i18n";
import Typo from "@/components/typography/Typo.astro";

const t = useTranslations("en");
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="menu">
    <a href="/privacy"><Typo text="Privacy" tag="p" size={'md'} decoration="underline"/></a>
    <Typo text={'\u{02022}'}/>
    <a href="/credits"><Typo text="Credis" tag="p" size={'md'} decoration="underline"/></a>
    <Typo text={'\u{02022}'}/>
    <a href="mailto:info@pixelcutter.io"><Typo text="Contacts" tag="p" size={'md'} decoration="underline"/></a>
  </div>
  <MarkdownText text={t('footer.text', {year: currentYear.toString()})} size={'md'} color="secondary" />
</footer>


<style lang="scss">
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--s-xxs);
  padding-inline: var(--s-xxl);
  margin-inline: calc(-1 * var(--s-xxl));
  padding-block: var(--s-xxl);
  background-color: var(--c-primary);
  margin-top: auto;
  text-align: center;
  
  @include media(sm) {
    flex-direction: row;
    justify-content: space-between;
  }
  
  @include media(lg) {
    padding-inline: var(--s-big);
    margin-inline: calc(-1 * var(--s-big));
  }
}

.footer :global(em) {
  font-style: normal;
  color: var(--c-accent);
}

.menu {
  display: flex;
  align-items: center;
  gap: var(--s-xxs);
}
</style>
