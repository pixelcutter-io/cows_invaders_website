---
import type {  MaxWidth } from "@/types/components.ts";

interface Props {
	maxWidth?: MaxWidth;
	class?: string;
}

const {
	maxWidth = "df",
	class: className,
} = Astro.props;



const style = {
	"--l-w-max": `var(--w-max-${maxWidth})`,
};
---

<section class:list={["section", className]} style={style}>
  <slot/>
</section>

<style lang="scss">
  .section {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-content: stretch;
    gap: var(--s-big);
  }
  
  .section > :global(*) {
    max-width: var(--l-w-max);
    margin-inline: auto;
  }
</style>
