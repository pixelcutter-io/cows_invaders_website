---
import type { ColorType, MaxWidth, SizeType } from "@/types/components.ts";

interface Props {
	maxWidth?: MaxWidth;
	class?: string;
}

const {
	maxWidth = "df",
	padding = "st",
	bgColor,
	class: className,
} = Astro.props;

const [pTop, pBottom] = Array.isArray(padding) ? padding : [padding, padding];

const style = {
	"--l-w-max": `var(--w-max-${maxWidth})`,
	"--l-p-top": `var(--s-${pTop})`,
	"--l-p-bottom": `var(--s-${pBottom})`,
	"--l-bg": bgColor ? `var(--c-${bgColor})` : "transparent",
};
---

<section class:list={["section", className]} style={style}>
  <slot/>
</section>

<style lang="scss">
  .section {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--s-big);
  }
  
  .section > :global(*) {
    max-width: var(--l-w-max);
    margin-inline: auto;
  }
</style>
