---
import HeroHome from "@/components/blocks/HeroHome.astro";
import MediaText from "@/components/blocks/MediaText.astro";
import Layout from "@/components/layouts/Layout.astro";
import CallToAction from "@/components/blocks/CallToAction.astro";
import Img1 from "@/assets/images/web_img_1.png";
import Img2 from "@/assets/images/web_img_2.png";
import {useTranslations} from "@/i18n/i18n.ts";
import Text from "@/components/blocks/Text.astro";


const t = useTranslations("en");
---

<Layout>
  <HeroHome />
	<MediaText id="game" title={t('block.media_game.title')} text={t('block.media_game.text')} image={Img1.src}/>
  <MediaText id="genesis" title={t('block.media_genesis.title')} text={t('block.media_genesis.text')} image={Img2.src} reverse/>
  <Text id="about" title={t('block.media_about.title')} text={t('block.media_about.text')}/>
  <CallToAction/>
</Layout>


<style lang="scss">
:global(.beta-section) {
  max-width: var(--w-max-xxl);
  padding-inline: var(--s-df);
  padding-block: var(--s-xxl);
  border-radius: var(--s-xxl);
  background-color: color-mix(in srgb, var(--c-secondary), transparent 98%);
  margin-inline: auto;
  text-align: center;
  
  @include media(sm) {
    padding-inline: var(--s-xxl);
    padding-block: var(--s-tr);
  }
}

:global(.beta-section) > :global(.btn-beta) {
  width: 100%;
  max-width: 20rem;
}
</style>
