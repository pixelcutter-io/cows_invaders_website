---

import Layout from "@/components/layouts/Layout.astro";

import {useTranslations} from "@/i18n/i18n.ts";
import Typo from "@/components/typography/Typo.astro";
import MarkdownText from "@/components/typography/MarkdownText.astro";
import HeroPage from "@/components/blocks/HeroPage.astro";
import Section from "@/components/layouts/Section.astro";

const t = useTranslations("en");
---

<Layout theme="default">
  <HeroPage title="Privacy Policy"/>
  <Section maxWidth="sm">
    <MarkdownText class="privacy" text={'Cows Invaders does not collect, store, or share any personal data or information from its users. The app works entirely offline and does not use any third-party analytics, advertising, or tracking services.\n\nIf you have any questions, please contact us at: [info@pixelcutter.io](mailto:info@pixelcutter.io)'} color={"secondary"} size={['df', 'xxl']}  />
    <Typo text="Last updated: February 2026" tag="p"/>
  </Section>

</Layout>

